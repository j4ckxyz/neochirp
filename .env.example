# ── NeoChirp Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is NEVER committed to git — it stays on your server only.

# ── Core ─────────────────────────────────────────────────────────────────────
# Your public domain (no trailing slash, no scheme)
APP_DOMAIN=chirp.j4ck.xyz

# Set to true when serving over HTTPS (always true with Cloudflare tunnels)
APP_HTTPS=true

# NEVER set to true in production — disables invite codes and rate limits
DEV_MODE=false

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Get this from: https://one.dash.cloudflare.com/ → Zero Trust → Tunnels
# Create a tunnel → copy the token here
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── Ollama (Semantic Trends) ─────────────────────────────────────────────────
# If running Ollama on the host machine (not in Docker):
#   Linux: use http://172.17.0.1:11434
#   Mac/Windows: use http://host.docker.internal:11434
# If you don't want semantic trends, leave as-is — it falls back gracefully.
OLLAMA_HOST=http://172.17.0.1:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_TIMEOUT=10
